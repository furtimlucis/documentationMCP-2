# Documentation reader MCP server configuration
# Copy this file to .env and fill in your values

# GitHub source (leave blank to skip)
GITHUB_OWNER=
GITHUB_REPO=
GITHUB_BRANCH=main
GITHUB_DOCS_PATH=docs
GITHUB_TOKEN=

# GitLab source (leave blank to skip)
# GITLAB_HOST defaults to https://gitlab.com — set for self-hosted instances
GITLAB_HOST=https://gitlab.com
GITLAB_NAMESPACE=
GITLAB_REPO=
GITLAB_BRANCH=main
GITLAB_DOCS_PATH=docs
GITLAB_TOKEN=

# Local fallback docs folder (used only when GitHub and GitLab are both unavailable)
DOCS_FOLDER=docs

# LanceDB document cache
# Path where LanceDB stores its files. Mount a persistent volume here in
# Docker/Kubernetes so the cache survives container restarts.
LANCEDB_PATH=./lancedb

# How often (in minutes) to check GitHub/GitLab for changed files
# The server uses blob SHAs to detect changes, so only updated files are re-fetched.
SYNC_INTERVAL_MINUTES=60
