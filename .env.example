# Documentation reader MCP server configuration
# Copy this file to .env and fill in your values

# GitHub source (leave blank to skip)
GITHUB_OWNER=
GITHUB_REPO=
GITHUB_BRANCH=main
GITHUB_DOCS_PATH=docs
GITHUB_TOKEN=

# GitLab source (leave blank to skip)
# GITLAB_HOST defaults to https://gitlab.com — set it for self-hosted instances
GITLAB_HOST=https://gitlab.com
GITLAB_NAMESPACE=
GITLAB_REPO=
GITLAB_BRANCH=main
GITLAB_DOCS_PATH=docs
GITLAB_TOKEN=

# Local fallback docs folder
DOCS_FOLDER=docs
